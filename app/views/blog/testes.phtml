<?php
// conexão com o banco
include_once('conexao.php');

// termo pesquisado
$q = trim($_GET['q'] ?? '');
$q_sql = "%$q%";

// paginação
$limite = 5;
$pagina = isset($_GET['pagina']) ? (int) $_GET['pagina'] : 1;
$inicio = ($pagina - 1) * $limite;

// busca no banco (ajuste os nomes das colunas/tabelas conforme seu projeto)
$sql = "SELECT p.*, c.nome AS categoria 
        FROM tb_posts p
        INNER JOIN tb_categorias c ON p.categoria_id = c.id
        WHERE p.titulo LIKE ? OR p.resumo LIKE ? OR p.conteudo LIKE ?
        ORDER BY p.data DESC
        LIMIT $inicio, $limite";

$stmt = $conn->prepare($sql);
$stmt->bind_param("sss", $q_sql, $q_sql, $q_sql);
$stmt->execute();
$result = $stmt->get_result();

// contar total de resultados (para paginação)
$sql_total = "SELECT COUNT(*) AS total 
              FROM tb_posts 
              WHERE titulo LIKE ? OR resumo LIKE ? OR conteudo LIKE ?";
$stmt_total = $conn->prepare($sql_total);
$stmt_total->bind_param("sss", $q_sql, $q_sql, $q_sql);
$stmt_total->execute();
$total = $stmt_total->get_result()->fetch_assoc()['total'];

$total_paginas = ceil($total / $limite);
?>

