<!-- CONTAINER: CRIAR / EDITAR POST (ADMIN) -->
<style>

</style>

<div class="container-post">
    
  <form method="POST" action="salvar.php" enctype="multipart/form-data" class="form-post">
    
    <h2>Criar nova postagem</h2>

    <div class="form-group">
      <label for="titulo">Título do post</label>
      <input type="text" id="titulo" name="titulo" required placeholder="Digite o título da postagem">
    </div>

    <div class="form-group">
      <label for="slug">Slug (URL)</label>
      <input type="text" id="slug" name="slug" placeholder="gerado-automaticamente">
      <small>Use apenas letras minúsculas e hífen</small>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="status">Status</label>
        <select name="status" id="status">
          <option value="rascunho">Rascunho</option>
          <option value="publicado">Publicado</option>
        </select>
      </div>

      <div class="form-group">
        <label for="imagem">Imagem de capa</label>
        <input type="file" id="imagem" name="imagem" accept="image/*">
      </div>
    </div>

    <div class="form-group">
      <label for="resumo">Resumo</label>
      <textarea id="resumo" name="resumo" rows="3" maxlength="160" placeholder="Resumo curto para SEO e listagem"></textarea>
    </div>

    <div class="form-group">
      <label for="conteudo">Conteúdo do post</label>
      <textarea id="conteudo" name="conteudo" rows="14" placeholder="Escreva o conteúdo completo da postagem"></textarea>
    </div>

    <div class="form-actions">
      <button type="submit" name="acao" value="rascunho" class="btn secondary">Salvar rascunho</button>
      <button type="submit" name="acao" value="publicar" class="btn primary">Publicar</button>
    </div>

  </form>

</div>

<script>
function gerarSlug(texto) {
  return texto
    .toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9 ]/g, '')
    .trim()
    .replace(/\s+/g, '-');
}

const tituloInput = document.getElementById('titulo');
const slugInput = document.getElementById('slug');
let slugEditado = false;

slugInput.addEventListener('input', () => slugEditado = true);

tituloInput.addEventListener('input', () => {
  if (!slugEditado) {
    slugInput.value = gerarSlug(tituloInput.value);
  }
});
</script>
