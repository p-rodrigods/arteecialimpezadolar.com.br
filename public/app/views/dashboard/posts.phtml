<script src="https://cdn.tiny.cloud/1/wn94rnmhymxxqz5ggtxu940tzy1qa78sl50knhqvs88zkul7/tinymce/6/tinymce.min.js"></script>
<script>
  // Função para gerar slug a partir do título
 function gerarSlug(texto) {
    return texto
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9 ]/g, '')
      .trim()
      .replace(/\s+/g, '-');
  }

  const tituloInput = document.getElementById('titulo');
  const slugInput = document.getElementById('slug');
  let slugEditado = false;

  slugInput.addEventListener('input', () => slugEditado = true);

  tituloInput.addEventListener('input', () => {
    if (!slugEditado) {
      slugInput.value = gerarSlug(tituloInput.value);
    }
  });

// Inicialização do TinyMCE para o campo de conteúdo
  tinymce.init({
  selector: '#conteudo',
  height: 400,
  menubar: false,
  plugins: 'lists link image code',
  toolbar: 'undo redo | blocks | bold italic | bullist numlist | blockquote | link image | removeformat | code',
  branding: false
  });  

</script>
