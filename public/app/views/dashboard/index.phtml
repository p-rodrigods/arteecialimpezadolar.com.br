  <main>
    <header>
      <h2>Dashboard</h2>
      <div class="user">Olá, Admin</div>
    </header>

    <section class="grid">
      <div class="card">
        <h3>Posts publicados</h3>
        <strong><?= $this->view->totalPosts ?></strong>
      </div>
      <div class="card">
        <h3>Rascunhos</h3>
        <strong><?= $this->view->totalRascunhos ?></strong>
      </div>
    </section>

    <table>
      <thead>
        <tr>
          <th>Título</th>
          <th>Status</th>
          <th>Data</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <?php foreach ($this->view->postsRecentes as $post): ?>
        <tr>
          <td><?= htmlspecialchars($post['titulo']) ?></td>
          <td>
            <?php if ($post['status'] === 'publicado'): ?>
              <span class="badge publicado">Publicado</span>
            <?php else: ?>
              <span class="badge rascunho">Rascunho</span>
            <?php endif; ?>
          </td>
          <td><?= date('d/m/Y', strtotime($post['created_at'])) ?></td>
          <td class="actions">
            <a href="#">Editar</a>
            <a href="#">Excluir</a>
          </td>
        </tr>
        <?php endforeach; ?>
      </tbody>
    </table>

  </main>
